<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Unwasteable" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryContainer">@color/green_soft</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <item name="colorSecondary">@color/green_primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/background_main</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/divider_soft</item>

        <item name="android:statusBarColor">@color/background_main</item>
        <item name="android:navigationBarColor">@color/white</item>

        <item name="materialButtonStyle">@style/Widget.Unwasteable.Button</item>
        <item name="textInputStyle">@style/Widget.Unwasteable.TextInputLayout</item>
    </style>

    <style name="Theme.Unwasteable" parent="Base.Theme.Unwasteable" />

    <style name="Widget.Unwasteable.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.Unwasteable.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="TextAppearance.Unwasteable.BottomNav.Active" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Unwasteable.BottomNav.Inactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

</resources>